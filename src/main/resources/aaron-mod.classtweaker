classTweaker v2 official

# Optimized Screenshots
accessible	class	com/mojang/blaze3d/platform/NativeImage$WriteCallback
accessible	method	com/mojang/blaze3d/platform/NativeImage$WriteCallback	<init>	(Ljava/nio/channels/WritableByteChannel;)V

# Particle Customization
accessible	class	net/minecraft/client/particle/FireworkParticles$SparkParticle

# December Christmas Chests
accessible	class	net/minecraft/client/renderer/item/properties/select/LocalTime$Data

# Chroma Text
accessible	method	net/minecraft/network/chat/Style	<init>	(Lnet/minecraft/network/chat/TextColor;Ljava/lang/Integer;Ljava/lang/Boolean;Ljava/lang/Boolean;Ljava/lang/Boolean;Ljava/lang/Boolean;Ljava/lang/Boolean;Lnet/minecraft/network/chat/ClickEvent;Lnet/minecraft/network/chat/HoverEvent;Ljava/lang/String;Lnet/minecraft/network/chat/FontDescription;)V

# Custom Vertex Formats
accessible	field	com/mojang/blaze3d/vertex/DefaultVertexFormat	POSITION_FORMAT	Lcom/mojang/blaze3d/GpuFormat;
accessible	field	com/mojang/blaze3d/vertex/DefaultVertexFormat	COLOR_FORMAT	Lcom/mojang/blaze3d/GpuFormat;
accessible	field	com/mojang/blaze3d/vertex/DefaultVertexFormat	UV0_FORMAT	Lcom/mojang/blaze3d/GpuFormat;
accessible	field	com/mojang/blaze3d/vertex/DefaultVertexFormat	UV1_FORMAT	Lcom/mojang/blaze3d/GpuFormat;
accessible	field	com/mojang/blaze3d/vertex/DefaultVertexFormat	UV2_FORMAT	Lcom/mojang/blaze3d/GpuFormat;
accessible	field	com/mojang/blaze3d/vertex/DefaultVertexFormat	NORMAL_FORMAT	Lcom/mojang/blaze3d/GpuFormat;
accessible	field	com/mojang/blaze3d/vertex/DefaultVertexFormat	LINE_WIDTH_FORMAT	Lcom/mojang/blaze3d/GpuFormat;

# Glow
accessible	class	net/minecraft/client/renderer/rendertype/RenderSetup$TextureBinding

# Interface Injections
inject-interface	net/minecraft/world/item/ItemStack	net/azureaaron/mod/injected/AaronModItemMeta
inject-interface	net/minecraft/client/MouseHandler	net/azureaaron/mod/injected/MouseGuiPositioner
inject-interface	net/minecraft/client/gui/screens/Screen	net/azureaaron/mod/injected/ScreenResizeMarker
inject-interface	com/mojang/blaze3d/platform/NativeImage	net/azureaaron/mod/injected/NativeImageMarker
inject-interface	net/minecraft/client/particle/SingleQuadParticle	net/azureaaron/mod/injected/ParticleAlphaMarker
inject-interface	net/minecraft/client/renderer/LevelRenderer	net/azureaaron/mod/injected/EntityRenderMarker
inject-interface	net/minecraft/client/renderer/feature/ItemFeatureRenderer$Submit	net/azureaaron/mod/injected/CustomGlowState
inject-interface	net/minecraft/client/renderer/rendertype/RenderType	net/azureaaron/mod/injected/GlowRenderTypeHolder
